# ── Required ──────────────────────────────────────────────
# OpenAI API key (used by both the worker and evaluator LLMs)
OPENAI_API_KEY=your_openai_key_here
# Serper API key for web search (https://serper.dev)
SERPER_API_KEY=your_serper_key_here

# ── Optional (defaults shown) ─────────────────────────────
# LLM that does the work
WORKER_MODEL=gpt-4o-mini
# LLM that judges the work (set a stronger model here if you like)
EVALUATOR_MODEL=gpt-4o-mini
# Cap on the worker<->evaluator retry loop
MAX_ITERATIONS=3
# Set to false to watch the Playwright browser run
HEADLESS=true
